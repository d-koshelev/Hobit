{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hobit",
  "version": "0.1.0",
  "identifier": "com.hobit.desktop",
  "build": {
    "beforeDevCommand": {
      "cwd": "../frontend",
      "script": "npm run dev -- --host 127.0.0.1 --port 5173 --strictPort",
      "wait": false
    },
    "beforeBuildCommand": {
      "cwd": "../frontend",
      "script": "npm run build"
    },
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hobit",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
